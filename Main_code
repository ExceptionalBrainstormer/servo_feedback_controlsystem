#include <Servo.h>
#define TRIG_PIN 4
#define ECHO_PIN 3
char rx_byte;

Servo s;
char val = 0;
int state;
int GND = 2;
int VIN = 5;
void setup() {
  // put your setup code here, to run once:
  s.attach(11);
  Serial.begin(4800); 
  pinMode(VIN, OUTPUT);
  pinMode(GND, OUTPUT);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(VIN, HIGH);
  digitalWrite(GND, LOW);
  s.write(0);                  // sets the servo position according to the scaled value
  delay(2000);
  s.write(90);
  s.write(180);                  // sets the servo position according to the scaled value
  delay(1000);
  s.write(90);
}
void loop() {
  // put your main code here, to run repeatedly:
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW); 
  long duration = pulseIn(ECHO_PIN, HIGH);
  float distance = duration * 0.034 / 2;// distance
  Serial.println(distance);
  val=3;// here you need to set the value like if you wnat to switch to state 1, write 1, fror state 2, write 2 and for the state3, write 3
  // here you could use your own convenient method to get the value of val variable as 1, 2, or 3.
  if(distance>=2 && distance<=3){//range of distance for being in state 1.
    state = 1;
  } 
  else if(distance<=5.30 && distance>=4.30){ //range of distance for being in state 2.
    state = 2;
  }
  else if(distance<=7 && distance>=5.5){ //range of distance for being in state 3.
    state = 3;
  }
  else{
    state = 4;
  }
  switch(val){
    case 1:
      switch(state){
        case 1:
          // stop
          s.write(90);
          Serial.println("state reached");
          break;
        case 2:
          // move clockwise
          s.write(180);
          break;
        case 3:
          // move anticlockwise
          s.write(0);

          break;
        case 4:
          // move clockwise
          s.write(180);
          break;
        break;
      }
    break;
    case 2:
      switch(state){
        case 1:
          // move anticlockwise 
          s.write(0);
          break;
        case 2:
          // stop
          s.write(90);
          break;
        case 3:
          // move clockwise
          s.write(180);
          break;
        case 4:
          // move clockwise
          s.write(180);
          break;
        break;
      }
    break;
    case 3:
      switch(state){
        case 1:
          // move clockwise
          s.write(180);
          break;
        case 2:
          // move anticlockwise
          s.write(0);
          break;
        case 3:
          // stop
          s.write(90);
          break;
        case 4:
          // move clockwise
          s.write(180);          
          break;
        break;
      }
    break;
    default:
      break;
    
  }
  if(val==5){
    s.write(180);
    delay(500);
    s.write(90);
  }
  if(val==6){
    s.write(0);
    delay(500);
    s.write(90);
  }
}
